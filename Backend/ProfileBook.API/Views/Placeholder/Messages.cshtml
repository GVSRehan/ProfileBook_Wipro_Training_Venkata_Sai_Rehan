@{
    ViewData["Title"] = "Messages Placeholder";
}

<h1>Messages Placeholder</h1>
<p class="muted">Static MVC placeholder for the messaging screen deliverable.</p>

<div class="grid two" style="margin-top: 20px;">
    <div>
        <h2>Conversations</h2>
        <p class="muted">Friend and group conversations would appear here.</p>
    </div>
    <div>
        <h2>Chat Area</h2>
        <label class="field">
            <span>Message</span>
            <textarea rows="5" placeholder="Type a message"></textarea>
        </label>
        <button class="button" type="button">Send</button>
    </div>
</div>
