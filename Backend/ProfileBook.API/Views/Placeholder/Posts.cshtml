@{
    ViewData["Title"] = "Posts Placeholder";
}

<h1>Posts Placeholder</h1>
<p class="muted">Static MVC placeholder for post creation and feed viewing.</p>

<div class="grid" style="margin-top: 20px;">
    <label class="field">
        <span>Create Post</span>
        <textarea rows="5" placeholder="Write something for the feed"></textarea>
    </label>
    <button class="button" type="button">Submit Post</button>
</div>

<hr style="margin: 28px 0; border: 0; border-top: 1px solid #e2e8f0;" />

<h2>Approved Feed Placeholder</h2>
<p class="muted">Approved posts would be listed here in the Angular application.</p>
