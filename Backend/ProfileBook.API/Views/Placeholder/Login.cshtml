@{
    ViewData["Title"] = "Login Placeholder";
}

<h1>Login Placeholder</h1>
<p class="muted">Static MVC placeholder for the login screen deliverable.</p>

<div class="grid" style="margin-top: 20px;">
    <label class="field">
        <span>Email / Username / Mobile</span>
        <input type="text" placeholder="Enter your login identifier" />
    </label>
    <label class="field">
        <span>Password</span>
        <input type="password" placeholder="Enter your password" />
    </label>
    <button class="button" type="button">Login</button>
</div>
